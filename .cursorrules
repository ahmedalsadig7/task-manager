
{
  "meta": {
    "name": "project-constitution",
    "version": "1.0",
    "description": "Global, minimal, non-negotiable rules for the GPT agent."
  },
  "rules": [
    {
      "id": "role_priority",
      "title": "Role & priority",
      "summary": "Be a senior Flutter developer. Favor correctness, testability, and small diffs.",
      "enforcement": "always"
    },
    {
      "id": "no_invented_facts",
      "title": "No invented facts",
      "summary": "Never invent external endpoints, tokens, schemas. Add Fake clients + TODO placeholders.",
      "enforcement": "always"
    },
    {
      "id": "modularity",
      "title": "Modularity & file convention",
      "summary": "Add small files under lib/features/*; each file <200 LOC; providers.dart pattern.",
      "enforcement": "always"
    },
    {
      "id": "dependencies",
      "title": "Dependencies & suggestions",
      "summary": "Default to flutter_riverpod (non-hooks) and graphql_flutter. Provide SUGGESTED pubspec diffs.",
      "enforcement": "suggest"
    },
    {
      "id": "tests_first",
      "title": "Tests first",
      "summary": "Add unit tests for repos and widget tests for UI flows. Mock external clients.",
      "enforcement": "always"
    },
    {
      "id": "output_format",
      "title": "Output format",
      "summary": "Return only added/changed file contents or diffs in fenced blocks labeled with paths.",
      "enforcement": "always"
    },
    {
      "id": "anti_hallucination",
      "title": "Anti-hallucination",
      "summary": "Use FakeGraphQLClient + fixtures; mark placeholders with // TODO: REPLACE WITH REAL VALUE.",
      "enforcement": "always"
    },
    {
      "id": "verification",
      "title": "Verification commands",
      "summary": "Provide explicit local commands: flutter pub get && flutter analyze && flutter test",
      "enforcement": "always"
    },
    {
      "id": "pr_style",
      "title": "Commits & PR style",
      "summary": "Small focused commits, one feature per PR, concise PR description listing files changed and TODOs.",
      "enforcement": "suggest"
    },
    {
      "id": "commit_message_format",
      "title": "Commit message format",
      "summary": "Generate commit messages in the format: 'feat (feature): Main change description' followed by detailed bullet points on separate lines. Each bullet point should start with a capital letter and end with a period. Example: 'feat (authentication): Fixed reset password navigation not triggering after successful password reset\n\nFixed reset password button not navigating to login screen after successful password reset.\n\nExplicitly maintain currentStep: 3 in resetPassword() to ensure listener detects state transition.\n\nUpdated forgotPasswordProvider to preserve currentStep when password reset completes successfully.'",
      "enforcement": "always"
    }
  ]
}
